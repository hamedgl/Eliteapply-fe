{"name":"eliteapply-frontend","version":"0.1.0","private":true,"type":"module","scripts":{"dev":"vite","build":"npm run build:client && npm run build:server && node scripts/prerender.mjs && npm run seo:check","build:client":"tsc -b && vite build","build:server":"vite build --ssr src/entry-server.tsx --outDir .prerender","preview":"vite preview","seo:check":"node scripts/check-seo.mjs","deploy":"rm -f dist/_redirects && npx wrangler deploy","typecheck":"tsc -b --pretty false","lint":"tsc -b --pretty false","test":"vitest run","api:generate":"openapi-typescript docs/api/openapi.json -o src/generated/api/schema.ts","api:check":"npm run api:generate && git diff --exit-code -- src/generated/api/schema.ts","api:usage":"node scripts/check-openapi-operation-usage.mjs"},"dependencies":{"@heroui/react":"^3.2.2","@heroui/styles":"^3.2.2","@tanstack/react-query":"^5.90.21","clsx":"^2.1.1","lucide-react":"^0.546.0","motion":"^12.42.2","react":"^19.0.0","react-dom":"^19.0.0","react-hook-form":"^7.62.0","react-router-dom":"^7.9.1","tailwind-merge":"^3.6.0","zod":"^4.1.9","zustand":"^5.0.8"},"devDependencies":{"@playwright/test":"^1.61.1","@testing-library/jest-dom":"^6.8.0","@testing-library/react":"^16.3.0","@testing-library/user-event":"^14.6.1","@types/node":"^24.5.2","@types/react":"^19.1.16","@types/react-dom":"^19.1.9","@vitejs/plugin-react":"^5.0.4","jsdom":"^27.0.0","openapi-typescript":"^7.9.1","typescript":"~5.8.3","vite":"^6.2.3","vitest":"^4.0.7"}}